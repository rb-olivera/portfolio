---
interface Props {
  number: string;
  label: string;
  title: string;
  subtitle?: string;
}
const { number, label, title, subtitle } = Astro.props;
---

<div class="mb-12">
  <div class="flex items-center gap-3 mb-4 text-xs uppercase tracking-[0.2em] font-mono text-muted">
    <span class="text-accent">{number}</span>
    <span class="h-px w-8 bg-border"></span>
    <span>{label}</span>
  </div>
  <h2 class="font-display text-4xl sm:text-5xl tracking-tight max-w-2xl">{title}</h2>
  {subtitle && <p class="text-muted mt-4 max-w-xl">{subtitle}</p>}
</div>
