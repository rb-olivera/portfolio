---
import type { Project } from "../data/content";
interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article class="group flex flex-col bg-surface border border-border rounded-2xl overflow-hidden hover:border-accent/60 transition-all duration-300">

  <!-- ── Header coloreado ── -->
  <div class="px-6 pt-6 pb-4 border-b border-border">

    <!-- Año + badge de curso -->
    <div class="flex items-start justify-between gap-3 mb-4 flex-wrap">
      <span class="text-xs font-mono text-muted">{project.year}</span>
      {project.course && (
        <span class="text-xs font-mono text-accent border border-accent/30 rounded-full px-2.5 py-0.5 leading-relaxed text-right">
          {project.course}
        </span>
      )}
    </div>

    <!-- Título -->
    <h3 class="font-display text-xl leading-snug mb-1 group-hover:text-accent transition-colors">
      {project.title}
    </h3>

    <!-- Herramientas en paréntesis como subtítulo -->
    <p class="text-xs font-mono text-muted">
      ({project.tools.join(" · ")})
    </p>
  </div>

  <!-- ── Cuerpo: secciones estructuradas ── -->
  <div class="flex flex-col flex-1 px-6 py-5 space-y-4 text-sm">

    <!-- Problema -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-muted mb-1">
        Problema a resolver
      </p>
      <p class="text-ink/85 leading-relaxed">{project.problem}</p>
    </div>

    <!-- Dataset -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-muted mb-1">
        Dataset utilizado
      </p>
      <p class="text-ink/75 leading-relaxed">{project.dataset}</p>
    </div>

    <!-- Herramientas (badges) -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-muted mb-2">
        Herramientas
      </p>
      <div class="flex flex-wrap gap-1.5">
        {project.tools.map((t) => (
          <span class="text-xs font-mono text-mint border border-mint/30 rounded-full px-2.5 py-0.5">
            {t}
          </span>
        ))}
      </div>
    </div>

    <!-- Resultados -->
    <div class="rounded-xl bg-surface-2 border border-border px-4 py-3">
      <p class="text-[10px] font-mono uppercase tracking-widest text-muted mb-1">
        Resultados
      </p>
      <p class="text-ink/85 leading-relaxed">{project.results}</p>
    </div>

  </div>

  <!-- ── Botones de acción ── -->
  <div class="px-6 pb-6 pt-2 flex flex-wrap gap-2 border-t border-border">
    {project.caso && (
      <a
        href={project.caso}
        target="_blank"
        rel="noopener"
        class="px-4 py-2 rounded-full bg-accent text-bg text-xs font-medium hover:opacity-90 transition-opacity inline-flex items-center gap-1"
      >
        Ver caso <span aria-hidden>↗</span>
      </a>
    )}
    {project.dashboard && (
      <a
        href={project.dashboard}
        target="_blank"
        rel="noopener"
        class="px-4 py-2 rounded-full border border-accent text-accent text-xs font-medium hover:bg-accent/10 transition-colors inline-flex items-center gap-1"
      >
        Ver dashboard <span aria-hidden>↗</span>
      </a>
    )}
    {project.repo && (
      <a
        href={project.repo}
        target="_blank"
        rel="noopener"
        class="px-4 py-2 rounded-full border border-border hover:border-ink text-xs transition-colors inline-flex items-center gap-1"
      >
        Ver código <span aria-hidden>↗</span>
      </a>
    )}
  </div>

</article>
